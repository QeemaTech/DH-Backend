APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=multi_vendor_e_commerce
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Tabby
TABBY_BASE_URL=https://api.tabby.ai
TABBY_PUBLIC_KEY=
TABBY_SECRET_KEY=
TABBY_MERCHANT_CODE=
TABBY_WEBHOOK_URL=
TABBY_WEBHOOK_HEADER_NAME=
TABBY_WEBHOOK_HEADER_VALUE=

# Eezee Pay (sandbox / reseller API — see vendor docs for request shapes)
EEZEEP_BASE_URL=https://sandbox.eezee-pay.com/api/v1
EEZEEP_EMAIL=
EEZEEP_PASSWORD=
# If password was stored under EEZEEP_PHONE by mistake, EEZEEP_PASSWORD is still preferred.
EEZEEP_PHONE=
EEZEEP_TOKEN=
# Stored in digital_merchants.company_name when syncing categories
# EEZEEP_COMPANY_NAME=eezee_pay
# User id for digital_products.last_update_by (must exist in users table)
# EEZEEP_SYNC_USER_ID=1
# EEZEEP_AUTH_HEADER=Authorization
# EEZEEP_AUTH_SCHEME=Bearer
# EEZEEP_TIMEOUT=30
# EEZEEP_CONNECT_TIMEOUT=15
# After login/regenerate, the new token is stored in cache for later calls (same as your request).
# EEZEEP_REMEMBER_TOKEN=true
# EEZEEP_TOKEN_CACHE_TTL=3600
# EEZEEP_TOKEN_CACHE_KEY=eezee_pay.access_token
# Vendor default path is /token/regenerate (not /regenerate-token).
# EEZEEP_REGENERATE_PATH=/token/regenerate
# On 401/403 invalid or expired token, call login once and retry (needs EEZEEP_EMAIL + password).
# EEZEEP_AUTO_LOGIN_ON_AUTH_ERROR=true
# When true, every authenticated request calls /login first and ignores EEZEEP_TOKEN (needs EEZEEP_EMAIL + password).
# EEZEEP_FRESH_LOGIN_EACH_REQUEST=false

# Deema Direct API (BNPL) — supports KWD (Kuwait) and BHD (Bahrain)
# Sandbox base: https://sandbox-api.deema.me
# Production base: https://api.deema.me
# Auth: Authorization: Basic {API Key}
# Sandbox verification code for all registered phone numbers: 123456
# DEMA_BASE_URL=https://sandbox-api.deema.me
# DEMA_API_PREFIX=/api/merchant/v1
# DEMA_API_KEY=
# DEMA_TIMEOUT=30
# DEMA_SUCCESS_URL="${APP_URL}/dema/success"
# DEMA_FAILURE_URL="${APP_URL}/dema/failure"
# Optional shared secret header for webhooks (configured in Deema Merchant Portal)
# DEMA_WEBHOOK_HEADER_NAME=
# DEMA_WEBHOOK_HEADER_VALUE=

# Optional WhatsApp Business / HTTP API for verification (see App\Services\WhatsAppService)
# WHATSAPP_MESSAGE_URL=
# WHATSAPP_API_TOKEN=
