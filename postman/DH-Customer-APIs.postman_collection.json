{
  "info": {
    "_postman_id": "9a6b9b21-1d3e-4f6c-9d33-0ed3a94b0f01",
    "name": "DH - Customer APIs",
    "description": "Customer-facing API requests for the DH Laravel backend.\n\nHow to use:\n- Set collection variables: base_url, token, country_id, locale\n- Run Auth → Login first (or Register), then set token.\n\nNotes:\n- Most endpoints require the 'locale' middleware; this collection sets Accept-Language by default.\n- Protected endpoints use Bearer token (Sanctum).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://dh.test" },
    { "key": "token", "value": "" },
    { "key": "country_id", "value": "" },
    { "key": "locale", "value": "en" },
    { "key": "product_id", "value": "" },
    { "key": "vendor_id", "value": "" },
    { "key": "category_id", "value": "" },
    { "key": "digital_product_id", "value": "" },
    { "key": "order_id", "value": "" },
    { "key": "address_id", "value": "" },
    { "key": "ticket_id", "value": "" },
    { "key": "invoice_id", "value": "" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Default headers for all requests",
          "pm.request.headers.upsert({ key: 'Accept', value: 'application/json' });",
          "pm.request.headers.upsert({ key: 'Accept-Language', value: pm.collectionVariables.get('locale') || 'en' });",
          "",
          "// Attach Bearer token if present",
          "const token = pm.collectionVariables.get('token');",
          "if (token && token.trim() !== '') {",
          "  pm.request.headers.upsert({ key: 'Authorization', value: `Bearer ${token}` });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Authentication & account flows.",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"phone\": \"555000\",\n  \"password\": \"password\",\n  \"password_confirmation\": \"password\",\n  \"country_id\": {{country_id}}\n}\n"
            },
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api", "auth", "register"] }
          }
        },
        {
          "name": "Login (sets token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "",
                  "// Try common token shapes",
                  "const json = pm.response.json();",
                  "const token = json.token || json.access_token || (json.data && (json.data.token || json.data.access_token));",
                  "if (token) {",
                  "  pm.collectionVariables.set('token', token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password\"\n}\n"
            },
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"] }
          }
        },
